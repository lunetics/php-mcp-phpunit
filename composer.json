{
    "name": "php-mcp/phpunit",
    "description": "MCP wrapper for PHPUnit - provides structured test results for LLM agents",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "PHP MCP Contributors"
        }
    ],
    "require": {
        "php": "^8.2",
        "php-mcp/server": "^1.0",
        "ext-dom": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "PhpMcp\\Phpunit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PhpMcp\\Phpunit\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/mcp-phpunit-server"
    ],
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}